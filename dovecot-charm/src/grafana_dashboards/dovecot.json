{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "datasource",
      "id": "loki",
      "name": "Loki",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Service Status",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "title": "Dovecot Exporter Up",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "targets": [
        {
          "expr": "up{instance=~\".*:9900\"}",
          "legendFormat": "{{juju_unit}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "displayName": "${__field.labels.juju_unit}"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "options": {
        "textMode": "value_and_name",
        "colorMode": "background",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "none"
      }
    },
    {
      "title": "Connected IMAP Sessions",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "targets": [
        {
          "expr": "increase(dovecot_auth_success_total{service=\"imap\",juju_application=~\"$juju_application\",juju_model=~\"$juju_model\",juju_model_uuid=~\"$juju_model_uuid\",juju_unit=~\"$juju_unit\"}[$__range])",
          "legendFormat": "{{juju_unit}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 1
      }
    },
    {
      "title": "Connected POP3 Sessions",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "targets": [
        {
          "expr": "increase(dovecot_auth_success_total{service=\"pop3\",juju_application=~\"$juju_application\",juju_model=~\"$juju_model\",juju_model_uuid=~\"$juju_model_uuid\",juju_unit=~\"$juju_unit\"}[$__range])",
          "legendFormat": "{{juju_unit}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 1
      }
    },
    {
      "title": "Authentication",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "panels": []
    },
    {
      "title": "Auth Success Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "targets": [
        {
          "expr": "rate(dovecot_auth_success_total{juju_application=~\"$juju_application\",juju_model=~\"$juju_model\",juju_model_uuid=~\"$juju_model_uuid\",juju_unit=~\"$juju_unit\"}[$__rate_interval])",
          "legendFormat": "{{service}} {{juju_unit}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      }
    },
    {
      "title": "Auth Failure Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "targets": [
        {
          "expr": "rate(dovecot_auth_failure_total{juju_application=~\"$juju_application\",juju_model=~\"$juju_model\",juju_model_uuid=~\"$juju_model_uuid\",juju_unit=~\"$juju_unit\"}[$__rate_interval])",
          "legendFormat": "{{service}} {{juju_unit}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      }
    },
    {
      "title": "Storage",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "panels": []
    },
    {
      "title": "Mail Storage Usage (/srv/mail)",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "targets": [
        {
          "expr": "1 - (node_filesystem_avail_bytes{mountpoint=\"/srv/mail\",juju_application=~\"$juju_application\",juju_model=~\"$juju_model\",juju_model_uuid=~\"$juju_model_uuid\",juju_unit=~\"$juju_unit\"} / node_filesystem_size_bytes{mountpoint=\"/srv/mail\",juju_application=~\"$juju_application\",juju_model=~\"$juju_model\",juju_model_uuid=~\"$juju_model_uuid\",juju_unit=~\"$juju_unit\"})",
          "legendFormat": "{{ juju_unit }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.7
              },
              {
                "color": "orange",
                "value": 0.85
              },
              {
                "color": "red",
                "value": 0.95
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 19
      }
    },
    {
      "title": "Mail Storage Free Bytes",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "targets": [
        {
          "expr": "node_filesystem_avail_bytes{mountpoint=\"/srv/mail\",juju_application=~\"$juju_application\",juju_model=~\"$juju_model\",juju_model_uuid=~\"$juju_model_uuid\",juju_unit=~\"$juju_unit\"}",
          "legendFormat": "{{ juju_unit }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 8,
        "y": 19
      }
    },
    {
      "title": "Logs",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "panels": []
    },
    {
      "title": "Mail Logs",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "${lokids}"
      },
      "targets": [
        {
          "expr": "{filename=\"/var/log/syslog\", juju_application=~\"$juju_application\",juju_model=~\"$juju_model\",juju_model_uuid=~\"$juju_model_uuid\",juju_unit=~\"$juju_unit\"} |~ \"dovecot:\""
        }
      ],
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 28
      }
    }
  ],
  "schemaVersion": 37,
  "style": "dark",
  "tags": [
    "imap-server",
    "mail",
    "dovecot"
  ],
  "templating": {
    "list": [
      {
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "lokids",
        "label": "Loki datasource",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "prometheusds",
        "label": "Prometheus datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "allValue": ".*",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "juju_model",
        "label": "Juju model",
        "datasource": {
          "uid": "${prometheusds}"
        },
        "definition": "label_values(up,juju_model)",
        "query": {
          "query": "label_values(up,juju_model)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 1,
        "sort": 0,
        "type": "query"
      },
      {
        "allValue": ".*",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "juju_model_uuid",
        "label": "Juju model uuid",
        "datasource": {
          "uid": "${prometheusds}"
        },
        "definition": "label_values(up{juju_model=~\"$juju_model\"},juju_model_uuid)",
        "query": {
          "query": "label_values(up{juju_model=~\"$juju_model\"},juju_model_uuid)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 1,
        "sort": 0,
        "type": "query"
      },
      {
        "allValue": ".*",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "juju_application",
        "label": "Juju application",
        "datasource": {
          "uid": "${prometheusds}"
        },
        "definition": "label_values(up{juju_model=~\"$juju_model\",juju_model_uuid=~\"$juju_model_uuid\"},juju_application)",
        "query": {
          "query": "label_values(up{juju_model=~\"$juju_model\",juju_model_uuid=~\"$juju_model_uuid\"},juju_application)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 1,
        "sort": 0,
        "type": "query"
      },
      {
        "allValue": ".*",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "juju_unit",
        "label": "Juju unit",
        "datasource": {
          "uid": "${prometheusds}"
        },
        "definition": "label_values(up{juju_model=~\"$juju_model\",juju_model_uuid=~\"$juju_model_uuid\",juju_application=~\"$juju_application\"},juju_unit)",
        "query": {
          "query": "label_values(up{juju_model=~\"$juju_model\",juju_model_uuid=~\"$juju_model_uuid\",juju_application=~\"$juju_application\"},juju_unit)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 1,
        "sort": 0,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "title": "Dovecot Server",
  "uid": "dovecot-server-overview"
}
